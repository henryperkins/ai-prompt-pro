    "check:prod": "npm run check:docs && npm run check:no-legacy-ui-imports && npm run check:no-legacy-ds-props && npm run check:no-deprecated-ds-bridges && npm run check:no-deprecated-textarea-usage && npm run check:no-duplicate-ds-entrypoints && STRICT_PRIMITIVE_IMPORTS=1 npm run check:no-primitive-ds-imports && npm run check:no-new-phosphor-imports && npm run check:no-literal-colors && npm run check:no-arbitrary-typography && npm run check:design-system-baseline && npm run lint && npm run test:unit && npm run build && npm run check:token-runtime",
    "report:design-system-baseline": "node scripts/generate-design-system-baseline.mjs",
    "preview": "vite preview",
    "capture:design-review": "playwright test playwright/design-review.capture.spec.ts",
    "swa:init": "swa init",
    "swa:start": "swa start",
    "swa:build": "swa build",
    "swa:deploy:dry-run": "swa deploy --env production --dry-run",
    "swa:deploy": "swa deploy --env production",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create promptforge-db",
    "d1:migrate": "wrangler d1 execute promptforge-db --remote --file=workers/d1/schema.sql",
    "d1:local-migrate": "wrangler d1 execute promptforge-db --local --file=workers/d1/schema.sql",
    "kv:create": "wrangler kv:namespace create SESSIONS",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'src/test/rls-community-*.test.ts'",
    "test:desktop": "playwright test playwright/builder.desktop.spec.ts",
    "test:mobile": "playwright test",
    "test:mobile:headed": "playwright test --headed",
    "test:rls": "dotenv -- vitest run src/test/rls-community-*.test.ts",
    "test:watch": "vitest"
