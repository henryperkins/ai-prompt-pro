VITE_NEON_PROJECT_ID="your-neon-project-id"
VITE_NEON_DATA_API_URL="https://your-endpoint.apirest.c-<region>.aws.neon.tech/neondb/rest/v1"
VITE_NEON_AUTH_URL="https://your-endpoint.neonauth.c-<region>.aws.neon.tech/neondb/auth"
VITE_NEON_PUBLISHABLE_KEY="optional-public-key-for-function-fallback"
VITE_AGENT_SERVICE_URL="https://your-agent-service.example.com"
# Optional: set a positive millisecond value to cap enhance requests client-side.
# Leave unset to disable the implicit client timeout.
# VITE_ENHANCE_REQUEST_TIMEOUT_MS="900000"
VITE_ENHANCE_TRANSPORT="auto"
VITE_ENHANCE_WS_CONNECT_TIMEOUT_MS="3500"

# Agent service runtime (Phase 3)
OPENAI_API_KEY=""
AZURE_OPENAI_API_KEY=""
AGENT_SERVICE_TOKEN=""
HOST="0.0.0.0"
PORT="8001"
NEON_AUTH_URL="https://your-endpoint.neonauth.c-<region>.aws.neon.tech/neondb/auth"
NEON_JWKS_URL="https://your-endpoint.neonauth.c-<region>.aws.neon.tech/neondb/auth/.well-known/jwks.json"
FUNCTION_PUBLIC_API_KEY="optional-public-key-for-signed-out-calls"
ALLOWED_ORIGINS="https://your-frontend.example.com,http://localhost:5173"
EXTRACT_MODEL="gpt-4.1-mini"
ENHANCE_PER_MINUTE="12"
ENHANCE_PER_DAY="300"
EXTRACT_PER_MINUTE="6"
EXTRACT_PER_DAY="120"
INFER_PER_MINUTE="15"
INFER_PER_DAY="400"
ENHANCE_WS_INITIAL_MESSAGE_TIMEOUT_MS="5000"
ENHANCE_WS_MAX_PAYLOAD_BYTES="65536"
ENHANCE_WS_MAX_CONNECTIONS_PER_IP="10"
# Optional: select a named profile from ~/.codex/config.toml for this service only.
# Example: CODEX_PROFILE="azure-5"
CODEX_PROFILE=""
# Optional provider override when ~/.codex/config.toml is unavailable.
# Example (single line JSON):
# {"model":"<your-azure-deployment-name>","model_provider":"azure","model_providers":{"azure":{"name":"Azure OpenAI","base_url":"https://<resource>.openai.azure.com/openai/v1","env_key":"AZURE_OPENAI_API_KEY","wire_api":"responses"}}}
CODEX_CONFIG_JSON=""
REQUIRE_PROVIDER_CONFIG="false"
# For Azure providers, set this to your Azure deployment name.
CODEX_MODEL=""
CODEX_MODEL_REASONING_EFFORT="high"

# Dev/local only: allows decoded JWT fallback if auth config/service is unavailable.
# Never enable this in production.
ALLOW_UNVERIFIED_JWT_FALLBACK="false"
ALLOW_UNVERIFIED_JWT_FALLBACK_IN_PRODUCTION="false"

# Leave empty unless running privileged integration tests.
NEON_SERVICE_ROLE_KEY=""
