# Cloudflare Workers Configuration
VITE_AUTH_WORKER_URL="https://promptforge.<your-subdomain>.workers.dev"
VITE_API_WORKER_URL="https://promptforge.<your-subdomain>.workers.dev"

# Optional: For local development
# VITE_AUTH_WORKER_URL="http://localhost:8787"
# VITE_API_WORKER_URL="http://localhost:8787"

# Agent service (prompt enhancement)
VITE_AGENT_SERVICE_URL="https://your-agent-service.example.com"
VITE_AGENT_PUBLIC_API_KEY="pk_live_your-public-ai-key"
VITE_ENHANCE_TRANSPORT="auto"
VITE_ENHANCE_WS_CONNECT_TIMEOUT_MS="3500"

# Email delivery worker (promptforge-email) — delivers transactional
# emails via Resend. Deploy with: wrangler deploy --config wrangler.email.toml
# Secrets are set via `wrangler secret put --config wrangler.email.toml`.
RESEND_API_KEY=""
# EMAIL_FROM=""  # Optional — defaults to "PromptForge <noreply@lakefrontdigital.io>"

# Password reset delivery — connects the auth worker to the email worker.
# If PASSWORD_RESET_DELIVERY_WEBHOOK_URL is unset, the worker keeps
# self-service reset disabled and the UI routes users to support instead.
PASSWORD_RESET_DELIVERY_WEBHOOK_URL="http://localhost:8788/send"
PASSWORD_RESET_DELIVERY_WEBHOOK_TOKEN=""
PASSWORD_RESET_PUBLIC_ORIGIN="http://localhost:8080"

# Agent service runtime variables
OPENAI_API_KEY=""
AGENT_SERVICE_TOKEN=""
FUNCTION_PUBLIC_API_KEY=""
AUTH_SESSION_VALIDATION_URL=""
HOST="0.0.0.0"
PORT="8001"
ALLOWED_ORIGINS="https://prompt.lakefrontdigital.io,http://localhost:8080"
EXTRACT_MODEL="gpt-4.1-mini"
ENHANCE_PER_MINUTE="12"
ENHANCE_PER_DAY="300"
EXTRACT_PER_MINUTE="6"
EXTRACT_PER_DAY="120"
INFER_PER_MINUTE="15"
INFER_PER_DAY="400"
ENHANCE_WS_INITIAL_MESSAGE_TIMEOUT_MS="5000"
ENHANCE_WS_MAX_PAYLOAD_BYTES="65536"
ENHANCE_WS_MAX_CONNECTIONS_PER_IP="10"
CODEX_CONFIG_JSON=""
CODEX_MODEL=""
CODEX_MODEL_REASONING_EFFORT="high"

# Optional Azure OpenAI provider compatibility. Leave unset for the direct
# OpenAI/DigitalOcean path.
AZURE_OPENAI_API_KEY=""

# Legacy Neon variables (KEEP FOR MIGRATION TRANSITION)
# These can be removed after full migration to Cloudflare
# VITE_NEON_PROJECT_ID=""
# VITE_NEON_DATA_API_URL=""
# VITE_NEON_AUTH_URL=""
# VITE_NEON_PUBLISHABLE_KEY=""
